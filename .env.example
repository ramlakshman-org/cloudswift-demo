# Resend — sends contact form and assessment wizard notification emails.
# Without it, submissions are logged to the server console instead
# (dev fallback, both forms still work).
RESEND_API_KEY=

# MongoDB Atlas — persists contact form and assessment wizard submissions
# as enquiries. Without MONGODB_URI, enquiries are logged to the console
# instead of saved (dev fallback) and /admin will show "MongoDB isn't
# configured yet".
MONGODB_URI=
MONGODB_DB=cloudswift

# Admin dashboard (/admin) — single shared master login, not per-user accounts.
# ADMIN_USERNAME defaults to "admin" if unset.
ADMIN_USERNAME=
ADMIN_PASSWORD=
# Optional: separate secret for signing admin session cookies.
# Falls back to ADMIN_PASSWORD if unset — set this explicitly in production
# so rotating the login password doesn't also invalidate session signing.
ADMIN_SESSION_SECRET=
